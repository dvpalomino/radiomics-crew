# Copy to .env and fill in. .env is gitignored — never commit a key.

# --- Provider ---
# The Anthropic API is billed separately from any Claude subscription: get a key and load
# prepaid credit at console.anthropic.com. Install the matching extra: pip install "crewai[anthropic]"
ANTHROPIC_API_KEY=sk-ant-...

RC_MODEL=anthropic/claude-haiku-4-5-20251001   # the four workers: cheap, high call volume
RC_MANAGER_MODEL=anthropic/claude-sonnet-5     # the panel chair: holds the goal across a long run
RC_TEMPERATURE=0.2
RC_MAX_PAPERS=12          # each included paper is ~500 chars of JSON the model writes by hand

# Other providers work the same way — install the extra and set the model string:
# OPENAI_API_KEY=sk-...          RC_MODEL=gpt-4o-mini
# GEMINI_API_KEY=...             RC_MODEL=gemini/gemini-2.0-flash
# Local and free, but small models handle tool-calling poorly — expect retries:
# RC_MODEL=ollama/llama3.1       OPENAI_API_BASE=http://localhost:11434

# --- Memory ---
# Off by default. crewAI's memory needs an embedder and defaults to OpenAI's, so turning this
# on makes an OPENAI_API_KEY mandatory even on an Anthropic-only or local setup. If you want it,
# pair it with a non-OpenAI embedder.
RC_MEMORY=false

# --- NCBI E-utilities (optional but recommended: 3 req/s -> 10 req/s with a key) ---
NCBI_EMAIL=you@example.org
NCBI_API_KEY=
